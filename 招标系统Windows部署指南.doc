            <td>pnpm (必须使用)</td>
        </tr>
        <tr>
            <td>默认端口</td>
            <td>5000</td>
        </tr>
        <tr>
            <td>Node 版本</td>
            <td>推荐 18-20 LTS</td>
        </tr>
    </table>

